              {
                "id": "call_echo_orig",
                "name": "echo",
                "arguments": {
                  "message": "original"
                }
              }
            ],
            "input_tokens": 100,
            "output_tokens": 25
          }
        },
        {
          "response": {
            "type": "text",
            "content": "Echoed: original",
            "input_tokens": 200,
            "output_tokens": 15
          }
        }
      ]
    },
    {
      "user_input": "/undo",
      "steps": [
        {
          "response": {
            "type": "text",
            "content": "Undone.",
            "input_tokens": 50,
            "output_tokens": 5
          }
        }
      ]
    },
    {
      "user_input": "/redo",
      "steps": [
        {
          "response": {
            "type": "text",
            "content": "Redone.",
            "input_tokens": 50,
            "output_tokens": 5
          }
        }
      ]
    }
  ]
}
